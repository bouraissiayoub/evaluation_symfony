{% extends 'base.html.twig' %}
{% block title %}Admin Panel{% endblock %}
{% block body %}
<h3 class="mb-4">Admin Panel</h3>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Email</th>
            <th>Name</th>
            <th>Roles</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for user in users %}
        <tr>
            <td>{{ user.email }}</td>
            <td>{{ user.firstName }} {{ user.lastName }}</td>
            <td>{{ user.roles|join(', ') }}</td>
            <td>
                {% if user.isActive %}
                    <span class="badge bg-success">Active</span>
                {% else %}
                    <span class="badge bg-danger">Suspended</span>
                {% endif %}
            </td>
            <td class="d-flex gap-2">
                <a href="{{ path('admin_make_manager', {id: user.id}) }}" class="btn btn-sm btn-outline-primary">Make Manager</a>
                {% if user.isActive %}
                    <a href="{{ path('admin_suspend', {id: user.id}) }}" class="btn btn-sm btn-danger">Suspend</a>
                {% else %}
                    <a href="{{ path('admin_activate', {id: user.id}) }}" class="btn btn-sm btn-success">Activate</a>
                {% endif %}
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
<div class="d-flex gap-2 mt-4">
    {% if page > 1 %}
        <a href="?page={{ page - 1 }}" class="btn btn-outline-secondary">Previous</a>
    {% endif %}
    <a href="?page={{ page + 1 }}" class="btn btn-outline-secondary">Next</a>
</div>
{% endblock %}