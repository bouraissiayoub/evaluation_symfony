<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Betting Platform{% endblock %}</title>
    </head>
    <body>
        <nav>
            <a href="{{ path('bet_index') }}">Events</a>
            <a href="{{ path('wallet_index') }}">My Wallet</a>
            {% if app.user %}
                <span>{{ app.user.firstName }}</span>
                <a href="{{ path('app_logout') }}">Logout</a>
            {% else %}
                <a href="{{ path('app_login') }}">Login</a>
                <a href="{{ path('app_register') }}">Register</a>
            {% endif %}
            <a href="{{ path('bet_history') }}">My Bets</a>
            {% if is_granted('ROLE_MANAGER') %}
                <a href="{{ path('event_index') }}">Manage Events</a>
            {% endif %}
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('admin_index') }}">Admin Panel</a>
            {% endif %}
        </nav>

        {% for message in app.flashes('error') %}
            <p style="color:red">{{ message }}</p>
        {% endfor %}

        {% for message in app.flashes('success') %}
            <p style="color:green">{{ message }}</p>
        {% endfor %}

        {% block body %}{% endblock %}
    </body>
</html>