<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}BetApp{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('css/app.css') }}">
</head>
<body class="bg-light">

<nav class="navbar navbar-dark bg-dark px-4">
    <a class="navbar-brand" href="{{ path('app_home') }}">BetApp</a>
    <div class="d-flex gap-3 align-items-center">
        <a class="text-white text-decoration-none" href="{{ path('bet_index') }}">Events</a>
        {% if app.user %}
            <a class="text-white text-decoration-none" href="{{ path('wallet_index') }}">Wallet</a>
            <a class="text-white text-decoration-none" href="{{ path('bet_history') }}">My Bets</a>
            {% if is_granted('ROLE_MANAGER') %}
                <a class="text-white text-decoration-none" href="{{ path('event_index') }}">Manage Events</a>
            {% endif %}
            {% if is_granted('ROLE_ADMIN') %}
                <a class="text-white text-decoration-none" href="{{ path('admin_index') }}">Admin</a>
            {% endif %}
            <span class="text-warning">{{ app.user.firstName }}</span>
            <a class="btn btn-outline-light btn-sm" href="{{ path('app_logout') }}">Logout</a>
        {% else %}
            <a class="btn btn-outline-light btn-sm" href="{{ path('app_login') }}">Login</a>
            <a class="btn btn-warning btn-sm" href="{{ path('app_register') }}">Register</a>
        {% endif %}
    </div>
</nav>

<div class="container mt-4">
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% block body %}{% endblock %}
</div>

</body>
</html>