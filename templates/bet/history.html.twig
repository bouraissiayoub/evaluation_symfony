{% extends 'base.html.twig' %}
{% block title %}My Bets{% endblock %}
{% block body %}
<h3 class="mb-4">My Bet History</h3>

{% for bet in bets %}
    <div class="card mb-3">
        <div class="card-body d-flex justify-content-between">
            <div>
                <strong>{{ bet.sportEvent.name }}</strong>
                <p class="mb-0 text-muted">{{ bet.issue.label }} — Odds: {{ bet.recordedOdds }}</p>
                <small class="text-muted">{{ bet.placedAt|date('d/m/Y H:i') }}</small>
            </div>
            <div class="text-end">
                <p class="fw-bold">{{ bet.amount }} €</p>
                {% if bet.status == 'GAGNE' %}
                    <span class="badge bg-success">GAGNE</span>
                {% elseif bet.status == 'PERDU' %}
                    <span class="badge bg-danger">PERDU</span>
                {% else %}
                    <span class="badge bg-warning text-dark">EN ATTENTE</span>
                {% endif %}
            </div>
        </div>
    </div>
{% else %}
    <div class="alert alert-info">No bets yet.</div>
{% endfor %}
{% endblock %}