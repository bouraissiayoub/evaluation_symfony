{% extends 'base.html.twig' %}
{% block title %}Events{% endblock %}
{% block body %}
<h3 class="mb-4">Available Events</h3>

{% for event in events %}
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between">
            <strong>{{ event.name }}</strong>
            <span class="badge bg-success">{{ event.sport }}</span>
        </div>
        <div class="card-body">
            <p>Participants: {{ event.participants }}</p>
            <p>Date: {{ event.eventDate|date('d/m/Y H:i') }}</p>
            <div class="row">
                {% for issue in event.issues %}
                    <div class="col-md-4">
                        <div class="border rounded p-3 mb-2">
                            <p class="fw-bold">{{ issue.label }}</p>
                            <p class="text-warning">Odds: {{ issue.currentOdds }}</p>
                            <form method="post" action="{{ path('bet_place') }}">
                                <input type="hidden" name="issueId" value="{{ issue.id }}">
                                <input type="number" name="amount" min="1" step="0.01" placeholder="Amount €" class="form-control mb-2">
                                <button type="submit" class="btn btn-warning w-100">Bet</button>
                            </form>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
{% else %}
    <div class="alert alert-info">No events available.</div>
{% endfor %}
{% endblock %}