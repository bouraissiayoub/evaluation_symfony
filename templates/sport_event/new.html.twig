{% extends 'base.html.twig' %}

{% block title %}New Event{% endblock %}

{% block body %}
    <h1>Create new event</h1>

    <form method="post">
        <label>Name</label>
        <input type="text" name="name" required>

        <label>Sport</label>
        <input type="text" name="sport" required>

        <label>Participants</label>
        <input type="text" name="participants" required>

        <label>Date</label>
        <input type="datetime-local" name="eventDate" required>

        <button type="submit">Create</button>
    </form>
{% endblock %}