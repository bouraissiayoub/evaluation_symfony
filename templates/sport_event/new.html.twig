{% extends 'base.html.twig' %}
{% block title %}New Event{% endblock %}
{% block body %}
<div style="max-width:500px">
    <h3 class="mb-4">Create new event</h3>
    <form method="post">
        <div class="mb-3">
            <label class="form-label">Name</label>
            <input type="text" name="name" class="form-control" required>
        </div>
        <div class="mb-3">
            <label class="form-label">Sport</label>
            <input type="text" name="sport" class="form-control" required>
        </div>
        <div class="mb-3">
            <label class="form-label">Participants</label>
            <input type="text" name="participants" class="form-control" required>
        </div>
        <div class="mb-3">
            <label class="form-label">Date</label>
            <input type="datetime-local" name="eventDate" class="form-control" required>
        </div>

        <h5 class="mt-4">Outcomes</h5>
        <div class="mb-3">
            <label class="form-label">Outcome 1</label>
            <input type="text" name="issues[]" class="form-control" placeholder="e.g. Team A wins" required>
        </div>
        <div class="mb-3">
            <label class="form-label">Outcome 2</label>
            <input type="text" name="issues[]" class="form-control" placeholder="e.g. Draw" required>
        </div>
        <div class="mb-3">
            <label class="form-label">Outcome 3</label>
            <input type="text" name="issues[]" class="form-control" placeholder="e.g. Team B wins" required>
        </div>

        <button type="submit" class="btn btn-primary">Create</button>
        <a href="{{ path('event_index') }}" class="btn btn-outline-secondary ms-2">Cancel</a>
    </form>
</div>
{% endblock %}