{% extends 'base.html.twig' %}
{% block title %}My Wallet{% endblock %}
{% block body %}
<h3 class="mb-4">My Wallet</h3>

<div class="card mb-4" style="max-width:400px">
    <div class="card-body text-center">
        <p class="text-muted">Balance</p>
        <h2 class="text-success">{{ user.balance }} €</h2>
    </div>
</div>

<div class="card" style="max-width:400px">
    <div class="card-body">
        <h5>Deposit money</h5>
        <form method="post" action="{{ path('wallet_deposit') }}" class="d-flex gap-2">
            <input type="number" name="amount" min="1" step="0.01" placeholder="Amount €" class="form-control">
            <button type="submit" class="btn btn-success">Deposit</button>
        </form>
    </div>
</div>
<div class="card mt-4" style="max-width:400px">
    <div class="card-body">
        <h5>Set bet limits</h5>
        <form method="post" action="{{ path('wallet_set_limits') }}">
            <div class="mb-3">
                <label class="form-label">Daily bet limit €</label>
                <input type="number" name="dailyBetLimit" min="1" step="0.01" class="form-control" value="{{ user.dailyBetLimit }}">
            </div>
            <div class="mb-3">
                <label class="form-label">Weekly bet limit €</label>
                <input type="number" name="weeklyBetLimit" min="1" step="0.01" class="form-control" value="{{ user.weeklyBetLimit }}">
            </div>
            <button type="submit" class="btn btn-primary">Save limits</button>
        </form>
    </div>
</div>
{% endblock %}